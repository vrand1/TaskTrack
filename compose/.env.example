# --- API ---
API_PORT=80
GRPC_PORT=50051
APP_DEBUG=true
LOG_LEVEL=
LOG_TO_FILES=true
GRPC_ENABLED=true

# --- PostgreSQL ---
POSTGRES_USER=task_user
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=tasks
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=change_me_please
REDIS_PORT=6379
REDIS_TASKS_LIST_TTL_SECONDS=300

# --- Soft-delete ---
SOFT_DELETE_RETENTION_DAYS=30
SOFT_DELETE_PURGE_INTERVAL_HOURS=24

# --- Auth (backend) ---
# local = POST /auth/token + свой JWT; external = свой AccessTokenValidator в коде
AUTH_PROVIDER=local
# database = таблица users; remote = внешний сервис/LDAP (нужен адаптер)
USER_STORE=database
JWT_SECRET=change_me_please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Dev users (после migrate): admin@example.dev / user@example.dev, password: password123

# DATABASE_URL и REDIS_URL для api задаются в docker-compose.yml

# При медленной/отстутствующей сети загрузки - Баны долетают и до либ :( 
# Pypi прямо в отказе был - https://skillbox.ru/media/code/v-rossii-sboil-pypi-osnovnoy-repozitoriy-paketov-dlya-python/
