                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/tasks/{{taskId}}/reopen",
            "description": "Один раз переводит задачу из `done` в `todo` вне FSM. Повторный reopen вернёт ошибку."
          }
