              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            },
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "description": "Переводит задачу в `done` по FSM (todo → in_progress → review → done). Для reopen сначала доведите задачу до `done`."
          }
        },
        {
          "name": "Reopen Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('was_reopened is true', function () {",
                  "    pm.expect(data.was_reopened).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
